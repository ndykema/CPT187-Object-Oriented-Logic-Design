				//to here for a double, so I ended up making a separate one for just this Method.
				System.out.println("Please TYPE a new value for the Item.");
				System.out.println("Example: 399.99");
				double newPrice = input.nextDouble();
				input.close();
				return newPrice;
			}
			
		}



