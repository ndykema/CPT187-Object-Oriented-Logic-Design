	int thing = toolList.get(mid).getToolName().compareToIgnoreCase(searchInput);
	System.out.println(toolList.get(mid).getToolName());
	if(toolList.get(mid).getToolName().compareToIgnoreCase(searchInput) == 0) 
	{
		exists = true;
		position = mid;
	}
	else if(toolList.get(mid).getToolName().compareToIgnoreCase(searchInput) < 0) {
		first = (mid+1);
	}
	else 
	{
		last = mid-1;
	}
	
	}
	if (exists = true)
	{
