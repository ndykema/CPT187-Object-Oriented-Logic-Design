{
	System.out.println("\n\n\t                   ~~~~~~~~~~~~~~~~~~");
	System.out.println("\t              ~~~~~~~~~~~~~~~~~~~~~~~~~~~~");
	System.out.println("\t         ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~");
	System.out.println("\t     ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~");
	System.out.println("\t ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~");
	System.out.println("\t |        _ _  Custom Dream Home Report  _ _          |");
	System.out.println("\t |       |_|_|                          |_|_|         |");
	System.out.println("\t |       |_|_|            |---|         |_|_|         |");
	System.out.println("\t |                        |   |                       |");
	System.out.println("\t |                        |  .|                       |");
	System.out.println("\t |                    @ @ |   | @ @                   |");
	System.out.println("\t |                    |/  |___| |/                    |");
	System.out.println("\t |____________________________________________________|");
	System.out.println("\n     ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~");
	System.out.println("\n     Plan:		Bedrooms:		Bathrooms:		Cost:	 ");
	System.out.printf("     %-13s%14d%25d%19.2f$\n",demoHouse.getFloorPlan(),demoHouse.getNumBedrooms(),demoHouse.getNumBathrooms(),demoHouse.totalMaterialCost());
	System.out.println("\n     ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n\n\n");
}


}
