package edu.cpt187.dykema.program4;

import java.io.*;
import java.util.*;

public class MainClass {
	public static String FILE_PATH = "Grades.txt";
	public static void main(String[] args) throws IOException {

		FileInputStream fileGrades = new FileInputStream(FILE_PATH);
		Scanner Grades = new Scanner (fileGrades);
		
		readFileTitle();
		
		while (Grades.hasNext())
		{
			String line = Grades.next();
			System.out.println(line);
		}
		Grades.close();
		
	}
	public static void readFileTitle() throws FileNotFoundException
	{
		FileInputStream fileGrades = new FileInputStream(FILE_PATH);
		Scanner Grades = new Scanner(fileGrades);
		String title = Grades.nextLine();
		System.out.println(title);
		Grades.close();
	}
}
