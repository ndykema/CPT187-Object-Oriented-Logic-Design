		while (menuSelection != 'A' && menuSelection != 'B' && menuSelection != 'Q') 
		{
			System.out.println("     Please enter a valid selection!\n\t\t Example input: A");
			menuSelection = borrowedInput.next().toUpperCase().charAt(0);
		}
	
