	public static int getNumberOfStudents(String FILE_PATH) throws IOException
	{
		int numberOfStudents=ZERO;
		FileInputStream File = new FileInputStream(FILE_PATH);
		Scanner dataFile = new Scanner (File);
		dataFile.nextLine();
		while(dataFile.hasNextLine()) 
		{
			dataFile.nextLine();
			numberOfStudents++;
		}
		File.close();
		return numberOfStudents;
	}
	
	public static int getNumberOfGrades(String FILE_PATH) throws IOException
	{
		int numberOfGrades =ZERO;
		FileInputStream File = new FileInputStream(FILE_PATH);
		Scanner dataFile = new Scanner (File);
		dataFile.nextLine();
		dataFile.next();
		while(dataFile.hasNextInt())
		{
			dataFile.nextInt();
			numberOfGrades++;
			System.out.print(numberOfGrades);
		}
		File.close();
		return numberOfGrades;
	}
	
	public static void readFileTitle() throws FileNotFoundException {
		FileInputStream fileGrades = new FileInputStream(FILE_PATH);
		Scanner Grades = new Scanner(fileGrades);
		String title = Grades.nextLine();
		System.out.println(title);
		Grades.close();
	}

	public static void readNames(int numStudents, int numGrades) throws FileNotFoundException {
		FileInputStream fileGrades = new FileInputStream(FILE_PATH);
		Scanner Grades = new Scanner(fileGrades);
		Grades.nextLine();
		for (int i = 0; i < numStudents; i++) {
			studentNames[i] = Grades.next();
			Grades.nextLine();
		}
	}

	public static void readGrades(int numGrades, int numStudents) throws FileNotFoundException {
	
		FileInputStream fileGrades = new FileInputStream(FILE_PATH);

		Scanner Grades = new Scanner(fileGrades);
		while (Grades.hasNext()) 
		{ 
			int Exam = 0;
				for (int a = 0; a<numStudents; a++)
					
				{
					int i=0;
						Grades.nextLine();
						Grades.next();
						double gradeTally =0;
						for (i = 0; i < numGrades; i++) {
							int number;
							number = Grades.nextInt();
							if (i == 7) 
							{
								Exam = number * 3;
								gradeTally += number;
							} 
							else if (i < 6) 
							{
								gradeTally += number;
							}
						}
						gradeTally += Exam;
						double averageGrade = gradeTally / 10;
						studentGrades[a]=averageGrade;	
				}
		}
	}

	public static void displayStudent(int numStudents, int numGrades) throws FileNotFoundException
	{
		readNames(numStudents,numGrades);
		readGrades(numGrades,numStudents);
		readFileTitle();
		for (int i=0; i<numStudents; i++)
		{
			
			System.out.printf("Student Name: %-15s  Grade: %.1f\n",studentNames[i],studentGrades[i]);
		}
	}
}
