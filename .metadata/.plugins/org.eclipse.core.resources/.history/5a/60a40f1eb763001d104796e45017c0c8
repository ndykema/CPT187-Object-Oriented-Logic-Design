package edu.cpt187.dykema.program4;

import java.io.*;
import java.util.*;

public class MainClass {
	public static int numStudents = 10;
	public static String FILE_PATH = "Grades.txt";
	public static double[] studentGrades = new double[numStudents];
	public static String[] studentNames = new String[numStudents];
	public static int ZERO =0;
	public static String[] menuOptions = {"Student with Highest Grade", "Student with Lowest Grade","Quit"};
	public static String[] menuSelections = {"A.)","B.)","Q"};
	public static void main(String[] args) throws IOException {
		Scanner input = new Scanner(System.in);
//ClassRoom Class1 = new ClassRoom(FILE_PATH);
getValidInput(input,menuSelections,menuOptions);


	}
	
	public static void displayMenu(String[] menuSelections,String[] menuOptions)
	{
		System.out.println("          Grade Accessing Program");
		System.out.println("\n\t     ***Menu Selection***");
		for (int i=0; i<menuOptions.length; i++)
		{
			System.out.printf("\t%s: %s\n",menuSelections[i],menuOptions[i]);
		}
	}
	
	public static void getValidInput(Scanner borrowedInput, String[] menuSelections,String[] menuOptions)
	{
		displayMenu(menuSelections,menuOptions);
		Scanner input = new Scanner(System.in);
		
		System.out.println("\n\t     Please make a selection!");
