	public static char getValidMenuSelection(Scanner borrowedInput)
	{
		char selection;
		displayMenu();
		selection = borrowedInput.next().toUpperCase().charAt(0);
		while (selection != 'A' && selection != 'B' && selection != 'Q'&& selection != 'C'&& selection != 'D') {
			System.out.println("\t  Please enter a valid selection!\n\t\t Example input: A");
			selection = borrowedInput.next().toUpperCase().charAt(0);
		}
		return selection;
	}
	
	public static void addTool(Scanner borrowedInput)
	{
		String toolName;
		String toolOwner;
		System.out.println("Please enter the name of the tool you wish to add to the Tool List!");
		toolName = borrowedInput.nextLine().toLowerCase();
		
		System.out.println("Please enter the owner of the tool! Example:Chad");
		toolOwner = borrowedInput.nextLine();
		Tool customTool = new Tool(toolName, toolOwner);
		ToolKeeper.addTool(customTool);
		
		System.out.printf("You added %s to the Tool List!", customTool);
	
	}
	
	public static Tool searchTool(Scanner borrowedInput) 
	{ 	
		String searchedTool;
		Tool tool;
		System.out.println("Please enter the name of the tool you are looking for!");
		System.out.println("NOTE: If there are spaces in your tool name, use a hypen instead!!");
		searchedTool = borrowedInput.next().toLowerCase();
		tool = ToolKeeper.findToolByName(searchedTool);
		return tool;
	}
	
	public static void removeTool(Scanner borrowedInput) 
	{ 	Tool discardedTool;
		String toolName;
		System.out.println("Please enter the tool you would like to remove from the Tool List!");
		toolName = borrowedInput.nextLine();
		discardedTool = ToolKeeper.findToolByName(toolName);
		ToolKeeper.removeTool(discardedTool);
		
		System.out.printf("You removed %s from the Tool List",discardedTool);
	}
	
