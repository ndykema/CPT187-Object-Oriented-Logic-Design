		Scanner Grades = new Scanner(fileGrades);
		String title = Grades.nextLine();
		System.out.println(title);
		Grades.close();
	}
	public static void readNames(int numStudents,int numGrades) throws FileNotFoundException
	{
		FileInputStream fileGrades = new FileInputStream(FILE_PATH);
		Scanner Grades = new Scanner(fileGrades);
		String[] studentNames = new String [numStudents];
		Grades.nextLine();
		for(int i=0; i<numStudents; i++) {
		studentNames[i] = Grades.next();
		Grades.nextLine();	
		System.out.printf("%s\n",studentNames[i]);
		}
	}
	public static void readGrades(int numGrades) throws FileNotFoundException
	{
