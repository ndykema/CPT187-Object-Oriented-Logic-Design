package edu.cpt187.dykema.program4;

import java.io.*;
import java.util.*;

public class MainClass {
	public static String FILE_PATH = "Grades.txt";
	
	public static void main(String[] args) throws IOException {
		int numStudents = 10;
		int numGrades = 8;
		FileInputStream fileGrades = new FileInputStream(FILE_PATH);
		Scanner Grades = new Scanner (fileGrades);
		
		//readFileTitle();
