		number = Grades.nextInt();
		if (i == 7)
		{
			 Exam = number*3;
			 gradeTally+=number;
		}
		else(i<7)
		{
			gradeTally+= number;	
		}
		System.out.println(gradeTally);
	}
	gradeTally += Exam;
	double averageGrade = gradeTally/100;
	System.out.println(Exam);
	System.out.println(gradeTally);
	System.out.print(averageGrade);
	}
	
	}


